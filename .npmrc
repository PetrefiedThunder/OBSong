# Force strict engine checking
engine-strict=true

# This project requires pnpm. Enforcement is via the root "preinstall" guard (which checks
# the package-manager user agent) plus the "packageManager" field + corepack. Note:
# engine-strict alone does NOT block npm, because the engines field has no npm exclusion.
# If you see a pnpm-required error, install pnpm: npm install -g pnpm@8.15.0
