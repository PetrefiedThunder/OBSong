# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# CORS: comma-separated allowed origins. When set, these REPLACE the built-in defaults
# (localhost is only allowed by default in development).
CORS_ORIGINS=http://localhost:3000

# HTTPS enforcement (production). CANONICAL_HOSTS restricts the HTTP->HTTPS redirect target
# to trusted hostnames (comma-separated), preventing open-redirects via the Host header.
ENFORCE_HTTPS=true
CANONICAL_HOSTS=toposonics.com,www.toposonics.com,app.toposonics.com

# Proxy trust. Leave unset (false) unless behind a known reverse proxy; then set to the
# number of trusted hops (e.g. 1) or a trusted CIDR. Do NOT set to `true` blindly — it lets
# clients spoof their IP via X-Forwarded-For and bypass rate limiting.
# TRUST_PROXY=1

# Rate limiting
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW=1 minute
# RATE_LIMIT_ALLOW_LIST=

# Monitoring (under-pressure). The /status route is only exposed in non-production.
# STATUS_ROUTE=/status
# MAX_EVENT_LOOP_DELAY=1000
# MAX_HEAP_USED_BYTES=209715200
# MAX_RSS_BYTES=314572800

# Supabase
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
