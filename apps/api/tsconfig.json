{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "incremental": false,
    // CommonJS so `node dist/server.js` (the declared main/start) runs under Node without
    // a "type": "module" package. Clearing the inherited path aliases makes
    // @toposonics/types resolve as an external workspace package (its built dist) instead
    // of pulling packages/types source into the program — which had raised rootDir to the
    // repo root and emitted dist/apps/api/src/server.js.
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {},
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/**/__tests__/**"]
}
